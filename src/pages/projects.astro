---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

const projects = await getCollection('projects');
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "") + "/";
---
<BaseLayout title="Projects">
  <section class="space-y-6">
    
    <div class="mb-10">
      <span class="text-xs font-bold tracking-widest text-rit-orange uppercase block mb-2">Active Work</span>
      <h1 class="text-3xl font-black tracking-tight text-text mb-2">Projects</h1>
      <p class="text-text-dim max-w-2xl text-base">A concise view of the lab’s current initiatives, experimental systems, and engineering collaborations.</p>
    </div>

    <div class="grid gap-6 grid-cols-1 md:grid-cols-2">
      {projects.map((project) => (
        <a href={`${baseUrl}projects/${project.slug}`} class="block group h-full">
          <article class="bg-bg-soft/40 border border-line p-6 rounded-xl flex flex-col justify-between min-h-[160px] h-full transition-all duration-200 group-hover:border-slate-500 group-hover:bg-[#111a30] shadow-sm">
            <div>
              <h2 class="text-xl font-bold text-text mb-1 group-hover:text-orange-500 transition-colors duration-200">{project.data.title}</h2>
              <p class="text-xs font-semibold text-rit-orange-text uppercase tracking-wider mb-3">{project.data.status}</p>
              <p class="text-sm text-text-dim leading-relaxed">{project.data.summary}</p>
            </div>
          </article>
        </a>
      ))}
    </div>
    
  </section>
</BaseLayout>
