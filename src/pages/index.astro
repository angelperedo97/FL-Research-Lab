---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  
  <div class="relative w-full mb-14 pt-4">
    
    <div id="vanta-bg" class="absolute inset-0 w-full h-full z-0 rounded-xl"></div>

    <div class="relative z-10 flex flex-col md:flex-row items-center gap-10 lg:gap-16">
      <div>
        <span class="text-xs font-bold tracking-widest text-rit-orange uppercase block mb-3">University of Texas Rio Grande Valley</span>
        <h1 class="text-4xl md:text-6xl font-black tracking-tight text-text leading-[1.1] mb-6">
          Decentralized data. <br />
          <span class="font-display italic font-normal text-rit-orange-text text-5xl md:text-7xl">Intelligent</span> security.
        </h1>
        <p class="text-base md:text-lg text-text-dim leading-relaxed max-w-4xl">
          The Federated Learning & Intelligent Systems Research Lab is directed by Dr. Sergei Chuprov in the Department of Computer Science at the University of Texas Rio Grande Valley (UTRGV). The primary research focus centers on Federated Learning foundations, specifically personalized frameworks and distributed optimization algorithms. The group additionally investigates interdisciplinary machine learning applications across sensing and computing domains.
        </p>
      </div>

      <div class="w-48 md:w-64 lg:w-80 shrink-0 mx-auto">
        <img 
          src="/FL-Research-Lab/logo.svg" 
          alt="FL Research Lab Logo" 
          class="w-full h-auto object-contain" 
        />
      </div>
    </div>
  </div>

  <div class="w-full text-center mt-16 mb-2">
    <h2 class="text-xl font-extrabold tracking-wide text-rit-orange-text uppercase">Research Topics</h2>
  </div>
  <div class="w-full mb-10 border-t border-line"></div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
    <div class="bg-bg-soft/40 border border-line p-6 rounded-xl flex flex-col justify-between min-h-[220px]">
      <div>
        <span class="text-xs font-bold tracking-wider text-rit-orange uppercase">Foundations</span>
        <h3 class="text-lg font-bold text-text mt-2 mb-3">Privacy-Preserving & Personalized FL</h3>
        <p class="text-sm text-text-dim leading-relaxed">Developing decentralized optimization strategies and client personalization mechanisms to resolve data heterogeneity across distributed edge networks while ensuring strict user privacy guarantees.</p>
      </div>
    </div>

    <div class="bg-bg-soft/40 border border-line p-6 rounded-xl flex flex-col justify-between min-h-[220px]">
      <div>
        <span class="text-xs font-bold tracking-wider text-rit-orange uppercase">Security</span>
        <h3 class="text-lg font-bold text-text mt-2 mb-3">Robustness in Distributed ML</h3>
        <p class="text-sm text-text-dim leading-relaxed">Investigating system-level vulnerabilities against adversarial corruption and manipulation. This work focuses on building robust model integrity evaluation metrics and deploying secure runtime monitoring architectures.</p>
      </div>
    </div>

    <div class="bg-bg-soft/40 border border-line p-6 rounded-xl flex flex-col justify-between min-h-[220px]">
      <div>
        <span class="text-xs font-bold tracking-wider text-rit-orange uppercase">Systems</span>
        <h3 class="text-lg font-bold text-text mt-2 mb-3">Intelligent Cyber-Physical Systems</h3>
        <p class="text-sm text-text-dim leading-relaxed">Engineering and deploying lightweight, hardware-efficient neural network models directly to edge nodes for smart infrastructure monitoring and automated environmental sensing.</p>
      </div>
    </div>
  </div>

  <div class="w-full my-12 border-t border-line"></div>

  <div class="bg-bg-elev/40 border border-line p-8 rounded-xl grid grid-cols-1 md:grid-cols-2 gap-10 items-start mt-8">
    <div class="text-sm flex flex-col gap-2">
      <div class="font-bold text-xs uppercase tracking-wider text-rit-orange-text mb-1">Location</div>
      <p class="text-text-dim text-base leading-relaxed">
        <strong>University of Texas Rio Grande Valley</strong><br />
        College of Engineering and Computer Science<br />
        Department of Computer Science — Office EIEAB 3.240
      </p>
    </div>

    <div class="text-sm flex flex-col gap-2">
      <div class="font-bold text-xs uppercase tracking-wider text-rit-orange-text mb-1">Contact Directory</div>
      <p class="text-text-dim text-base leading-relaxed">
        <strong>Lab Director:</strong> Dr. Sergei Chuprov (Assistant Professor)<br />
        <strong>Email:</strong> <a href="mailto:sergei.chuprov@utrgv.edu" class="text-text hover:text-rit-orange transition-colors underline font-medium">sergei.chuprov@utrgv.edu</a><br />
        <strong>Phone:</strong> 956-665-3305
      </p>
    </div>
  </div>

</BaseLayout>

<script is:inline src={`${import.meta.env.BASE_URL}three.min.js`}></script>
<script is:inline src={`${import.meta.env.BASE_URL}vanta.dots.min.js`}></script>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    if (window.VANTA && window.VANTA.DOTS) {
      window.VANTA.DOTS({
        el: "#vanta-bg",
        mouseControls: true,
        touchControls: true,
        gyroControls: false,
        minHeight: 200.00,
        minWidth: 200.00,
        scale: 1.00,
        scaleMobile: 1.00,
        color: 0xf05023,
        backgroundColor: 0x0b0f17,
        size: 3.00,
        spacing: 35.00,  
        showLines: false    // Prevents the ball of lines from appearing
      });
    } else {
      console.error("Scripts failed to load. Double-check your exact filenames in the public folder.");
    }
  });
</script>
