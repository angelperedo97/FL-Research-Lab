---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

const resources = await getCollection('resources');

// Sort by order field (lowest first), then alphabetically
const sortedResources = resources.sort((a, b) => {
  const orderA = a.data.order ?? 999;
  const orderB = b.data.order ?? 999;
  if (orderA !== orderB) return orderA - orderB;
  return a.data.title.localeCompare(b.data.title);
});

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "") + "/";
---

<BaseLayout title="Resources">
  <section class="space-y-6">
    
    <div class="mb-10">
      <span class="text-xs font-bold tracking-widest text-rit-orange uppercase block mb-2">Knowledge Base</span>
      <h1 class="text-3xl font-black tracking-tight text-text mb-2">Resources</h1>
      <p class="text-text-dim max-w-2xl text-base">Guides, tutorials, and reference materials for lab members and prospective researchers.</p>
    </div>

    <div class="grid gap-6 grid-cols-1 md:grid-cols-2">
      {sortedResources.map((resource) => (
        <a href={`${baseUrl}resources/${resource.slug}`} class="block group h-full no-underline">
          <article class="bg-bg-soft/40 border border-line p-6 rounded-xl flex flex-col justify-between min-h-[160px] h-full transition-all duration-200 group-hover:border-slate-500 group-hover:bg-[#111a30] shadow-sm">
            <div>
              {resource.data.icon && (
                <span class="text-2xl mb-3 block">{resource.data.icon}</span>
              )}
              <h2 class="text-xl font-bold text-text mb-1 group-hover:text-orange-500 transition-colors duration-200">{resource.data.title}</h2>
              <p class="text-sm text-text-dim leading-relaxed">{resource.data.summary}</p>
            </div>
          </article>
        </a>
      ))}
    </div>
    
  </section>
</BaseLayout>
