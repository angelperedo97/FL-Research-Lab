---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPeople = await getCollection('people');
  return allPeople.map((person) => ({
    params: { slug: person.slug },
    props: { person },
  }));
}

const { person } = Astro.props;
const { Content } = await person.render();

const allPublications = await getCollection('publications');
const allProjects = await getCollection('projects');

// Extract and normalize the base URL path configuration for GitHub Pages routing
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

/**
 * HELPER FUNCTION: Strips prefixes like Dr. or Prof. and extra spacing
 * so that academic and card layouts match perfectly.
 */
const stripTitles = (str: string) => {
  return str
    .toLowerCase()
    .replace(/^(dr\.|prof\.|mr\.|ms\.)\s+/i, '')
    .trim();
};

// Multi-scenario matching algorithm checking raw text strings, list values, or object schemas
const isMemberAssociated = (memberList, personName, personSlug) => {
  if (!memberList) return false;
  
  // Strip "Dr." from the profile card name (e.g., "Dr. Sergei Chuprov" -> "sergei chuprov")
  const cleanPersonName = stripTitles(personName);
  const cleanPersonSlug = personSlug.toLowerCase().trim();

  return memberList.some(member => {
    if (!member) return false;
    
    // Scenario 1: If it is a string array item
    if (typeof member === 'string') {
      const cleanMemberName = stripTitles(member);
      // Dual directional match check for ultimate safety
      return cleanMemberName.includes(cleanPersonName) || cleanPersonName.includes(cleanMemberName);
    }
    
    // Scenario 2: If Astro parsed it as a Content Relationship reference object
    if (typeof member === 'object') {
      if (member.id && member.id.toLowerCase().trim() === cleanPersonSlug) return true;
      if (member.data?.name) {
        const cleanMemberDataName = stripTitles(member.data.name);
        return cleanMemberDataName.includes(cleanPersonName) || cleanPersonName.includes(cleanMemberDataName);
      }
    }
    
    return false;
  });
};

const personPublications = allPublications
  .filter((pub) => isMemberAssociated(pub.data.authors, person.data.name, person.slug))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const selectedPublications = personPublications
  .filter((pub) => pub.data.selected === true)
  .sort((a, b) => (a.data.selected_order || 999) - (b.data.selected_order || 999))
  .slice(0, 5);

const selectedIds = new Set(selectedPublications.map(p => p.id));
const otherPublications = personPublications.filter((pub) => !selectedIds.has(pub.id));

const personProjects = allProjects.filter((proj) => 
  isMemberAssociated(proj.data.contributors, person.data.name, person.slug)
);
---

<BaseLayout title={person.data.name}>
  <main class="max-w-4xl mx-auto px-4 py-12 text-white">
    
    <div class="flex flex-col items-center text-center space-y-4 mb-8">
      {person.data.avatar && (
        <img 
          src={`${baseUrl}${person.data.avatar}`} 
          alt={person.data.name} 
          class="w-32 h-32 rounded-full object-cover border-2 border-slate-800 shadow-md"
        />
      )}
      <div>
        <h1 class="text-4xl font-bold tracking-tight">{person.data.name}</h1>
        <p class="text-orange-600 font-medium mt-1">{person.data.role}</p>
      </div>
    </div>

    <div class="prose prose-invert max-w-2xl mx-auto text-center text-slate-300 leading-relaxed mb-12">
      <Content />
      {person.data.bio && <p>{person.data.bio}</p>}
    </div>

    {personPublications.length > 0 && (
      <div class="mt-12">
        <hr class="border-slate-800 my-8" />
        <h3 class="text-xs uppercase tracking-[0.3em] text-slate-400 font-bold mb-6">Selected Research</h3>
        <div class="space-y-4">
          {selectedPublications.length > 0 ? selectedPublications.map((pub) => (
            <article class="p-5 bg-[#0f172a] border border-slate-800 rounded-xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
              <div class="space-y-1">
                <p class="text-[11px] font-semibold tracking-widest text-slate-500 uppercase">
                  {pub.data.venue || 'Conference'} • {new Date(pub.data.date).getFullYear()}
                </p>
                <h4 class="text-base font-semibold text-white leading-snug">{pub.data.title}</h4>
                {pub.data.authors && pub.data.authors.length > 0 && (
                  <p class="text-sm text-slate-400">{pub.data.authors.join(', ')}</p>
                )}
              </div>
              {pub.data.link && (
                <a href={pub.data.link} target="_blank" rel="noopener noreferrer" class="shrink-0 text-xs text-slate-400 border border-slate-800 rounded-full px-3 py-1.5 hover:bg-slate-800 hover:text-white transition-all">
                  Link ↗
                </a>
              )}
            </article>
          )) : <p class="text-slate-500 text-sm italic">No selected publications explicitly set yet.</p>}
        </div>

        {otherPublications.length > 0 && (
          <div class="mt-6">
            <button id="toggle-pubs" class="text-sm font-semibold text-orange-600 hover:text-orange-500 transition-colors flex items-center gap-2">
              Show all publications <span id="toggle-icon">↓</span>
            </button>
            <div id="other-pubs" class="hidden mt-4 space-y-4">
              {otherPublications.map((pub) => (
                <article class="p-5 bg-[#0f172a] border border-slate-800 rounded-xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                  <div class="space-y-1">
                    <p class="text-[11px] font-semibold tracking-widest text-slate-500 uppercase">
                      {pub.data.venue || 'Conference'} • {new Date(pub.data.date).getFullYear()}
                    </p>
                    <h4 class="text-base font-semibold text-white leading-snug">{pub.data.title}</h4>
                    {pub.data.authors && pub.data.authors.length > 0 && (
                      <p class="text-sm text-slate-400">{pub.data.authors.join(', ')}</p>
                    )}
                  </div>
                  {pub.data.link && (
                    <a href={pub.data.link} target="_blank" rel="noopener noreferrer" class="shrink-0 text-xs text-slate-400 border border-slate-800 rounded-full px-3 py-1.5 hover:bg-slate-800 hover:text-white transition-all">
                      Link ↗
                    </a>
                  )}
                </article>
              ))}
            </div>
          </div>
        )}
      </div>
    )}

    {personProjects.length > 0 && (
      <div class="mt-12">
        <hr class="border-slate-800 my-8" />
        <h3 class="text-xs uppercase tracking-[0.3em] text-slate-400 font-bold mb-6">Projects</h3>
        <div class="space-y-4">
          {personProjects.map((project) => (
            <div class="p-6 bg-[#0f172a] border border-slate-800 rounded-2xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 shadow-sm">
              <div class="space-y-1.5 flex-1">
                <p class="text-xs font-semibold tracking-widest text-orange-600 uppercase">
                  {project.data.status}
                </p>
                <h4 class="text-lg font-semibold text-white leading-snug">{project.data.title}</h4>
                <p class="text-sm text-slate-400 leading-relaxed">{project.data.summary}</p>
              </div>
              
              <div class="flex gap-2 shrink-0 self-end sm:self-center">
                {project.data.poster && (
                  <a href={project.data.poster} target="_blank" rel="noopener noreferrer" class="text-xs text-slate-400 border border-slate-800 rounded-full px-3 py-1.5 hover:bg-slate-800 hover:text-white transition-all">
                    Poster 📋
                  </a>
                )}
                {project.data.link && (
                  <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="text-xs text-slate-400 border border-slate-800 rounded-full px-3 py-1.5 hover:bg-slate-800 hover:text-white transition-all">
                    Project ↗
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </main>
</BaseLayout>

<script>
  const toggleBtn = document.getElementById('toggle-pubs');
  const otherPubs = document.getElementById('other-pubs');

  if (toggleBtn && otherPubs) {
    toggleBtn.addEventListener('click', () => {
      otherPubs.classList.toggle('hidden');
      if (otherPubs.classList.contains('hidden')) {
        toggleBtn.innerHTML = 'Show all publications <span id="toggle-icon">↓</span>';
      } else {
        toggleBtn.innerHTML = 'Hide all publications <span id="toggle-icon">↑</span>';
      }
    });
  }
</script>
