---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPeople = await getCollection('people');
  return allPeople.map((person) => ({
    params: { slug: person.slug },
    props: { person },
  }));
}

const { person } = Astro.props;
const { Content } = await person.render();

const allPublications = await getCollection('publications');
const allProjects = await getCollection('projects');

// Extract and normalize the base URL path configuration for GitHub Pages routing
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

/**
 * HELPER FUNCTION: Strips prefixes like Dr. or Prof. and extra spacing
 * so that academic and card layouts match perfectly.
 */
const stripTitles = (str: string) => {
  return str
    .toLowerCase()
    .replace(/^(dr\.|prof\.|mr\.|ms\.)\s+/i, '')
    .trim();
};

// Multi-scenario matching algorithm checking raw text strings, list values, or object schemas
const isMemberAssociated = (memberList, personName, personSlug) => {
  if (!memberList) return false;
  
  // Strip "Dr." from the profile card name (e.g., "Dr. Sergei Chuprov" -> "sergei chuprov")
  const cleanPersonName = stripTitles(personName);
  const cleanPersonSlug = personSlug.toLowerCase().trim();

  return memberList.some(member => {
    if (!member) return false;
    
    // Scenario 1: If it is a string array item
    if (typeof member === 'string') {
      const cleanMemberName = stripTitles(member);
      // Dual directional match check for ultimate safety
      if (cleanMemberName.includes(cleanPersonName) || cleanPersonName.includes(cleanMemberName)) {
        return true;
      }
      
      // Fallback for abbreviated first names (e.g., "s. chuprov" matching "sergei chuprov")
      const personParts = cleanPersonName.split(' ');
      const memberParts = cleanMemberName.split(' ');
      if (personParts.length >= 2 && memberParts.length >= 2) {
        const pLast = personParts[personParts.length - 1];
        const mLast = memberParts[memberParts.length - 1];
        if (pLast === mLast && personParts[0][0] === memberParts[0][0]) {
          return true;
        }
      }
      return false;
    }
    
    // Scenario 2: If Astro parsed it as a Content Relationship reference object
    if (typeof member === 'object') {
      if (member.id && member.id.toLowerCase().trim() === cleanPersonSlug) return true;
      if (member.data?.name) {
        const cleanMemberDataName = stripTitles(member.data.name);
        if (cleanMemberDataName.includes(cleanPersonName) || cleanPersonName.includes(cleanMemberDataName)) {
          return true;
        }
        const mParts = cleanMemberDataName.split(' ');
        const pParts = cleanPersonName.split(' ');
        if (mParts.length >= 2 && pParts.length >= 2) {
          const mLast = mParts[mParts.length - 1];
          const pLast = pParts[pParts.length - 1];
          if (mLast === pLast && mParts[0][0] === pParts[0][0]) {
            return true;
          }
        }
      }
    }
    
    return false;
  });
};

const personPublications = allPublications
  .filter((pub) => isMemberAssociated(pub.data.authors, person.data.name, person.slug))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const groupedPersonPublications = personPublications.reduce((acc, pub) => {
  const year = new Date(pub.data.date).getFullYear() || 'Unknown Year';
  if (!acc[year]) acc[year] = [];
  acc[year].push(pub);
  return acc;
}, {} as Record<string, typeof personPublications>);

const sortedPersonYears = Object.keys(groupedPersonPublications).sort((a, b) => Number(b) - Number(a));

const personProjects = allProjects.filter((proj) => 
  isMemberAssociated(proj.data.contributors, person.data.name, person.slug)
);
---

<BaseLayout title={person.data.name}>
  <main class="max-w-4xl mx-auto px-4 py-12 text-white">
    
    <div class="flex flex-col items-center text-center space-y-4 mb-8">
      {person.data.avatar && (
        <img 
          src={`${baseUrl}${person.data.avatar}`} 
          alt={person.data.name} 
          class="w-32 h-32 rounded-full object-cover border-2 border-slate-800 shadow-md"
        />
      )}
      <div>
        <h1 class="text-4xl font-bold tracking-tight">{person.data.name}</h1>
        <p class="text-orange-600 font-medium mt-1">{person.data.role}</p>

        {/* Contact Links */}
        <div class="flex items-center justify-center gap-4 mt-4 text-slate-400">
          {/* Email */}
          {person.data.email && (
            <a href={`mailto:${person.data.email}`} class="hover:text-orange-500 transition-colors" title="Email">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </a>
          )}

          {/* Website */}
          {person.data.website && (
            <a href={person.data.website} target="_blank" rel="noopener noreferrer" class="hover:text-orange-500 transition-colors" title="Website">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            </a>
          )}

          {/* LinkedIn */}
          {person.data.linkedin && (
            <a href={person.data.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-orange-500 transition-colors" title="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
          )}

          {/* Google Scholar */}
          {person.data.scholar && (
            <a href={person.data.scholar} target="_blank" rel="noopener noreferrer" class="hover:text-orange-500 transition-colors" title="Google Scholar">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M6 18.8v-4L2.3 13a1 1 0 0 0-1.3 1v3.5a2.5 2.5 0 0 0 5 0z"/><path d="M21.5 13v6a2 2 0 0 1-2 2H13"/></svg>
            </a>
          )}

          {/* CV */}
          {person.data.cv && (
            <a href={person.data.cv.startsWith('http') ? person.data.cv : `${baseUrl}/${person.data.cv.replace(/^\//, "")}`} target="_blank" rel="noopener noreferrer" class="hover:text-orange-500 transition-colors" title="Curriculum Vitae (CV)">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M9 15h6"/><path d="M9 11h6"/></svg>
            </a>
          )}
        </div>
      </div>
    </div>

    <div class="prose prose-invert max-w-2xl mx-auto text-center text-slate-300 leading-relaxed mb-12">
      <Content />
      {person.data.bio && <p>{person.data.bio}</p>}
    </div>

    {personPublications.length > 0 && (
      <div class="mt-12">
        <hr class="border-slate-800 my-8" />
        <h3 class="text-xs uppercase tracking-[0.3em] text-slate-400 font-bold mb-6">
          Publications
        </h3>
        
        <div class="space-y-10">
          {sortedPersonYears.map((year) => (
            <div>
              <div class="flex items-center gap-4 mb-4">
                <h4 class="text-lg font-bold text-slate-300">{year}</h4>
                <div class="h-px bg-slate-800 flex-1"></div>
              </div>
              <div class="space-y-4">
                {groupedPersonPublications[year].map((pub) => (
                  <article class="p-5 bg-[#0f172a] border border-slate-800 rounded-xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-all hover:border-slate-700">
                    <div class="space-y-1 flex-1">
                      <p class="text-[11px] font-semibold tracking-widest text-slate-500 uppercase">
                        {pub.data.venue || 'Conference'}
                      </p>
                      <h5 class="text-base font-semibold text-white leading-snug">{pub.data.title}</h5>
                      {pub.data.authors && pub.data.authors.length > 0 && (
                        <p class="text-sm text-orange-600/90 font-medium">
                          {Array.isArray(pub.data.authors) ? pub.data.authors.join(', ') : pub.data.authors}
                        </p>
                      )}
                    </div>
                    {pub.data.link && (
                      <a href={pub.data.link} target="_blank" rel="noopener noreferrer" class="shrink-0 text-xs text-slate-400 border border-slate-800 rounded-full px-3 py-1.5 hover:bg-slate-800 hover:text-white transition-all">
                        Link ↗
                      </a>
                    )}
                  </article>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {personProjects.length > 0 && (
      <div class="mt-12">
        <hr class="border-slate-800 my-8" />
        <h3 class="text-xs uppercase tracking-[0.3em] text-slate-400 font-bold mb-6">Projects</h3>
        <div class="space-y-4">
          {personProjects.map((project) => (
            <div class="p-6 bg-[#0f172a] border border-slate-800 rounded-2xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 shadow-sm">
              <div class="space-y-1.5 flex-1">
                <p class="text-xs font-semibold tracking-widest text-orange-600 uppercase">
                  {project.data.status}
                </p>
                <h4 class="text-lg font-semibold text-white leading-snug">{project.data.title}</h4>
                <p class="text-sm text-slate-400 leading-relaxed">{project.data.summary}</p>
              </div>
              
              <div class="flex gap-2 shrink-0 self-end sm:self-center">
                {project.data.poster && (
                  <a href={project.data.poster} target="_blank" rel="noopener noreferrer" class="text-xs text-slate-400 border border-slate-800 rounded-full px-3 py-1.5 hover:bg-slate-800 hover:text-white transition-all">
                    Poster 📋
                  </a>
                )}
                {project.data.link && (
                  <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="text-xs text-slate-400 border border-slate-800 rounded-full px-3 py-1.5 hover:bg-slate-800 hover:text-white transition-all">
                    Project ↗
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </main>
</BaseLayout>


