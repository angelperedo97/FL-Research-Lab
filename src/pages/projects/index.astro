---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const projects = await getCollection('projects');
---
<BaseLayout title="Projects">
  <section class="space-y-6">
    <div class="card">
      <p class="text-sm uppercase tracking-[0.4em] text-orange-600">Active work</p>
      <h1 class="section-heading mt-4">Projects</h1>
      <p class="mt-4 max-w-2xl text-slate-700 dark:text-slate-300">A concise view of the lab’s current initiatives, experimental systems, and engineering collaborations.</p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {projects.map((project) => (
        <article class="card-compact">
          <h2 class="text-xl font-semibold">{project.data.title}</h2>
          <p class="mt-2 text-orange-600">{project.data.status}</p>
          <p class="mt-3 text-slate-600 dark:text-slate-400">{project.data.summary}</p>
          {project.data.contributors ? (
            <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">Contributors: {project.data.contributors.filter(Boolean).map((person) => person?.data?.name ?? 'Unknown').join(', ')}</p>
          ) : null}
          {project.data.link ? <a class="mt-4 inline-flex text-sm font-semibold text-orange-600" href={project.data.link}>More details</a> : null}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
