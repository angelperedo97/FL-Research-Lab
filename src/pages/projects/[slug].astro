---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  return allProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const allPublications = await getCollection('publications');
const allPeople = await getCollection('people');

// Extract and normalize the base URL path configuration for GitHub Pages routing
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

/**
 * HELPER FUNCTION: Strips prefixes like Dr. or Prof. and extra spacing
 */
const stripTitles = (str: string) => {
  return str
    .toLowerCase()
    .replace(/^(dr\.|prof\.|mr\.|ms\.)\s+/i, '')
    .trim();
};

const projectPublications = allPublications
  .filter((pub) => {
    if (!project.data.related_publications) return false;
    return project.data.related_publications.includes(pub.id) || project.data.related_publications.includes(pub.slug);
  })
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const projectContributors = (project.data.contributors || []).map(contributorName => {
  const cleanContributorName = stripTitles(contributorName);
  const match = allPeople.find(p => {
    const cleanPersonName = stripTitles(p.data.name);
    return cleanPersonName.includes(cleanContributorName) || cleanContributorName.includes(cleanPersonName);
  });
  return {
    name: contributorName,
    slug: match ? match.slug : null
  };
});

---

<BaseLayout title={project.data.title}>
  <main class="max-w-4xl mx-auto px-4 py-12 text-white">
    
    <div class="flex flex-col items-center text-center space-y-4 mb-8">
      <div>
        <p class="text-xs font-semibold tracking-widest text-orange-600 uppercase mb-3">{project.data.status}</p>
        <h1 class="text-4xl font-bold tracking-tight">{project.data.title}</h1>

        {/* Contact/Resource Links */}
        <div class="flex items-center justify-center gap-4 mt-6 text-slate-400">
          {project.data.github && (
            <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="hover:text-orange-500 transition-colors" title="GitHub Repository">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </a>
          )}
          {project.data.link && (
            <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="hover:text-orange-500 transition-colors" title="Project Website">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            </a>
          )}
          {project.data.poster && (
            <a href={project.data.poster.startsWith('http') ? project.data.poster : `${baseUrl}/${project.data.poster.replace(/^\//, "")}`} target="_blank" rel="noopener noreferrer" class="hover:text-orange-500 transition-colors" title="Project Poster">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
            </a>
          )}
        </div>
      </div>
    </div>

    <div class="prose prose-invert max-w-2xl mx-auto text-slate-300 leading-relaxed mb-12">
      <Content />
    </div>

    {projectContributors.length > 0 && (
      <div class="mt-12 max-w-2xl mx-auto">
        <hr class="border-slate-800 my-8" />
        <h3 class="text-xs uppercase tracking-[0.3em] text-slate-400 font-bold mb-6">Contributors</h3>
        <ul class="flex flex-wrap gap-3 list-none p-0 m-0">
          {projectContributors.map((contributor) => (
            <li class="m-0 p-0">
              {contributor.slug ? (
                <a href={`${baseUrl}/people/${contributor.slug}`} class="no-underline inline-flex items-center px-4 py-2 bg-[#0f172a] border border-slate-800 rounded-full text-sm font-medium text-white hover:border-slate-600 hover:text-orange-500 transition-colors">
                  {contributor.name}
                </a>
              ) : (
                <span class="inline-flex items-center px-4 py-2 bg-[#0f172a] border border-slate-800 rounded-full text-sm font-medium text-slate-400">
                  {contributor.name}
                </span>
              )}
            </li>
          ))}
        </ul>
      </div>
    )}

    {projectPublications.length > 0 && (
      <div class="mt-12 max-w-2xl mx-auto">
        <hr class="border-slate-800 my-8" />
        <h3 class="text-xs uppercase tracking-[0.3em] text-slate-400 font-bold mb-6">Related Publications</h3>
        <div class="space-y-4">
          {projectPublications.map((pub) => (
            <article class="p-5 bg-[#0f172a] border border-slate-800 rounded-xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
              <div class="space-y-1">
                <p class="text-[11px] font-semibold tracking-widest text-slate-500 uppercase">
                  {pub.data.venue || 'Conference'} • {new Date(pub.data.date).getFullYear()}
                </p>
                <h4 class="text-base font-semibold text-white leading-snug">{pub.data.title}</h4>
                {pub.data.authors && pub.data.authors.length > 0 && (
                  <p class="text-sm text-orange-600/90 font-medium">{pub.data.authors.join(', ')}</p>
                )}
              </div>
              {pub.data.link && (
                <a href={pub.data.link} target="_blank" rel="noopener noreferrer" class="shrink-0 text-xs text-slate-400 border border-slate-800 rounded-full px-3 py-1.5 hover:bg-slate-800 hover:text-white transition-all">
                  Link ↗
                </a>
              )}
            </article>
          ))}
        </div>
      </div>
    )}

  </main>
</BaseLayout>
