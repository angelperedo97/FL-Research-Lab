---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

const allPublications = await getCollection('publications');

// Sort publications by date (newest first)
const sortedPublications = allPublications.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});

// Group publications by year
const groupedPublications = sortedPublications.reduce((acc, pub) => {
  const year = new Date(pub.data.date).getFullYear() || 'Unknown Year';
  if (!acc[year]) acc[year] = [];
  acc[year].push(pub);
  return acc;
}, {} as Record<string, typeof sortedPublications>);

const sortedYears = Object.keys(groupedPublications).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="Publications">
  <section class="space-y-6 max-w-5xl mx-auto px-4 py-8">
    <div class="mb-8">
      <p class="text-sm uppercase tracking-[0.4em] text-orange-600">Public record</p>
      <h1 class="section-heading mt-4 text-white text-4xl font-bold">Publications</h1>
      <p class="mt-4 max-w-2xl text-slate-300">Research outputs from the FL Research Lab, including conference articles, reports, and technical notes.</p>
    </div>

    <div class="space-y-12">
      {sortedYears.map((year) => (
        <div>
          <div class="flex items-center gap-4 mb-6">
            <h2 class="text-2xl font-bold text-white">{year}</h2>
            <div class="h-px bg-slate-800 flex-1"></div>
          </div>
          <div class="space-y-4">
            {groupedPublications[year].map((publication) => (
              <article class="p-6 bg-[#0f172a] border border-slate-800 rounded-2xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 shadow-sm transition-all hover:border-slate-700">
                <div class="flex items-start gap-6 w-full">
                  <div class="space-y-1.5 flex-1">
                    <p class="text-xs font-semibold tracking-widest text-slate-400 uppercase">
                      {publication.data.venue || 'Publication'}
                    </p>
                    <h2 class="text-lg font-semibold text-white leading-snug">
                      {publication.data.title}
                    </h2>
                    <p class="text-sm text-orange-600/90 font-medium">
                      {
                        publication.data.authors 
                          ? (Array.isArray(publication.data.authors) ? publication.data.authors.join(', ') : publication.data.authors)
                          : ''
                      }
                    </p>
                  </div>
                </div>

                {publication.data.link && (
                  <a 
                    href={publication.data.link} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="shrink-0 text-xs font-medium text-slate-400 border border-slate-800 rounded-full px-4 py-2 hover:bg-slate-800 hover:text-white transition-all flex items-center gap-1 self-end sm:self-center"
                  >
                    Link ↗
                  </a>
                )}
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
