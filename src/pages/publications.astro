---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

const allPublications = await getCollection('publications');

// Sort publications by date (newest first)
const sortedPublications = allPublications.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});

// Control how many show up before the "See more" button
const initialCount = 5;
const visiblePubs = sortedPublications.slice(0, initialCount);
const hiddenPubs = sortedPublications.slice(initialCount);
---

<BaseLayout title="Publications">
  <section class="space-y-6">
    <div class="card bg-[#0f172a] border border-slate-800">
      <p class="text-sm uppercase tracking-[0.4em] text-orange-600">Public record</p>
      <h1 class="section-heading mt-4 text-white">Publications</h1>
      <p class="mt-4 max-w-2xl text-slate-300">Research outputs from the FL Research Lab, including conference articles, reports, and technical notes.</p>
    </div>

    <div class="space-y-4">
      {visiblePubs.map((publication) => (
        <article class="p-6 bg-[#0f172a] border border-slate-800 rounded-2xl flex flex-col md:flex-row items-start gap-6 shadow-sm">
          <div class="text-3xl font-serif text-orange-600 shrink-0">
            {new Date(publication.data.date).getFullYear() || 'Year'}
          </div>
          <div>
            <p class="text-xs font-semibold tracking-widest text-slate-400 uppercase mb-1">
              {publication.data.venue || 'Publication'}
            </p>
            <h2 class="text-lg font-semibold text-white mb-1">{publication.data.title}</h2>
            <p class="text-sm text-slate-400">
              {publication.data.authors ? publication.data.authors.filter(Boolean).map((author) => author?.data?.name ?? 'Unknown').join(', ') : ''}
            </p>
          </div>
        </article>
      ))}

      <div id="extra-pubs" class="hidden space-y-4">
        {hiddenPubs.map((publication) => (
          <article class="p-6 bg-[#0f172a] border border-slate-800 rounded-2xl flex flex-col md:flex-row items-start gap-6 shadow-sm">
            <div class="text-3xl font-serif text-orange-600 shrink-0">
              {new Date(publication.data.date).getFullYear() || 'Year'}
            </div>
            <div>
              <p class="text-xs font-semibold tracking-widest text-slate-400 uppercase mb-1">
                {publication.data.venue || 'Publication'}
              </p>
              <h2 class="text-lg font-semibold text-white mb-1">{publication.data.title}</h2>
              <p class="text-sm text-slate-400">
                 {publication.data.authors ? publication.data.authors.filter(Boolean).map((author) => author?.data?.name ?? 'Unknown').join(', ') : ''}
              </p>
            </div>
          </article>
        ))}
      </div>

      {hiddenPubs.length > 0 && (
        <button id="show-more-btn" class="mt-4 px-6 py-2 text-sm font-semibold text-orange-600 border border-orange-600 rounded-full hover:bg-orange-600 hover:text-white transition-colors">
          See all publications
        </button>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const btn = document.getElementById('show-more-btn');
  const extraContent = document.getElementById('extra-pubs');

  if (btn && extraContent) {
    btn.addEventListener('click', () => {
      extraContent.classList.remove('hidden');
      btn.style.display = 'none';
    });
  }
</script>
