---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

const publications = await getCollection('publications');
---
<BaseLayout title="Publications">
  <section class="space-y-6">
    <div class="card">
      <p class="text-sm uppercase tracking-[0.4em] text-orange-600">Public record</p>
      <h1 class="section-heading mt-4">Publications</h1>
      <p class="mt-4 max-w-2xl text-slate-700 dark:text-slate-300">Research outputs from the FL Research Lab, including conference articles, reports, and technical notes.</p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {publications.map((publication) => (
        <article class="card-compact">
          <h2 class="text-xl font-semibold">{publication.data.title}</h2>
          <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">{publication.data.date}</p>
          <p class="mt-3 text-slate-600 dark:text-slate-400">{publication.data.summary}</p>
          {publication.data.authors ? (
            <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">Authors: {publication.data.authors.filter(Boolean).map((author) => author?.data?.name ?? 'Unknown').join(', ')}</p>
          ) : null}
          {publication.data.link ? <a class="mt-4 inline-flex text-sm font-semibold text-orange-600" href={publication.data.link}>View publication</a> : null}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
