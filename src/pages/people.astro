---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

const allPeople = await getCollection('people'); 

// Sort so Dr. Chuprov is always first, the rest are alphabetical
const sortedPeople = allPeople.sort((a, b) => {
  if (a.data.name === "Dr. Sergei Chuprov") return -1;
  if (b.data.name === "Dr. Sergei Chuprov") return 1;
  return a.data.name.localeCompare(b.data.name);
});
---

<BaseLayout title="People">
  <section class="space-y-6">
    <div class="card">
      <p class="text-sm uppercase tracking-[0.4em] text-orange-600">Research team</p> [cite: 7]
      <h1 class="section-heading mt-4">People</h1> [cite: 7]
      <p class="mt-4 max-w-2xl text-slate-700 dark:text-slate-300">Discover the primary lab investigators, research staff, and contributors shaping the project portfolio.</p> [cite: 7]
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {sortedPeople.map((person) => {
        // Automatically extract up to 2 initials
        const initials = person.data.name
          .split(' ')
          .map(n => n[0])
          .join('')
          .substring(0, 2)
          .toUpperCase();

        return (
          <article class="card-compact flex items-center gap-4">
            
            {/* Avatar or Initials */}
            {person.data.avatar ? (
              <img src={person.data.avatar} alt={person.data.name} class="w-16 h-16 rounded-full object-cover shrink-0 ring-1 ring-slate-200 dark:ring-slate-700" />
            ) : (
              <div class="w-16 h-16 rounded-full bg-slate-100 dark:bg-slate-800 text-orange-600 flex items-center justify-center text-xl font-serif font-bold shrink-0 ring-1 ring-slate-200 dark:ring-slate-800">
                {initials}
              </div>
            )}
            
            {/* Text Content */}
            <div>
              <h2 class="text-lg font-semibold text-slate-900 dark:text-white">{person.data.name}</h2> [cite: 7]
              <p class="text-sm text-orange-600">{person.data.role}</p> [cite: 8]
            </div>

          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
