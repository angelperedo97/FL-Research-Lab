---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

const people = await getCollection('people');
---
<BaseLayout title="People">
  <section class="space-y-6">
    <div class="card">
      <p class="text-sm uppercase tracking-[0.4em] text-orange-600">Research team</p>
      <h1 class="section-heading mt-4">People</h1>
      <p class="mt-4 max-w-2xl text-slate-700 dark:text-slate-300">Discover the primary lab investigators, research staff, and contributors shaping the project portfolio.</p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {people.map((person) => (
        <article class="card-compact">
          <h2 class="text-xl font-semibold">{person.data.name}</h2>
          <p class="mt-2 text-orange-600">{person.data.role}</p>
          <p class="mt-3 text-slate-600 dark:text-slate-400">{person.data.bio}</p>
          {person.data.website ? <a class="mt-4 inline-flex text-sm font-semibold text-orange-600" href={person.data.website}>Website</a> : null}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
