---
import "../styles/global.css";
const { title = 'FL Research Lab' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | FL Research Lab</title>
    <meta name="description" content="FL Research Lab site for research, projects, publications, people, and news." />
  </head>
  <body class="bg-bg text-text min-h-screen relative flex flex-col antialiased">
    <div class="max-w-7xl w-full mx-auto flex-1 flex flex-col relative z-10">
      
      <header class="sticky top-0 z-20 border-b border-line bg-bg/90 backdrop-blur">
        <div class="flex items-center justify-between gap-4 px-6 py-5 w-full">
          
          <a href="/" class="font-extrabold text-xl tracking-tight text-text hover:text-rit-orange transition-colors">
            FL Research Lab
          </a>
          
          <nav class="flex items-center gap-6 text-sm font-semibold text-text-dim">
            <a href="/" class="hover:text-rit-orange transition-colors">Research</a>
            <a href="/projects" class="hover:text-rit-orange transition-colors">Projects</a>
            <a href="/publications" class="hover:text-rit-orange transition-colors">Publications</a>
            <a href="/people" class="hover:text-rit-orange transition-colors">People</a>
            <a href="/news" class="hover:text-rit-orange transition-colors">News</a>
          </nav>

        </div>
      </header>

      <main class="px-6 py-12 flex-1 relative z-10">
        <slot />
      </main>

      <footer class="px-6 py-8 text-center text-xs text-text-faint border-t border-line">
        &copy; {new Date().getFullYear()} FL Research Lab. Powered by Astro & Tailwind 4.
      </footer>

    </div>
  </body>
</html>
