---
import "../styles/global.css";
const { title = 'FL Research Lab' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | FL Research Lab</title>
    <meta name="description" content="FL Research Lab site for research, projects, publications, people, and news." />
    
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  </head>
  <body class="bg-bg text-text min-h-screen relative flex flex-col antialiased">
    
    <header class="sticky top-0 z-20 w-full bg-bg-elev border-b-2 border-rit-orange px-6 py-4">
      <div class="flex items-center justify-between gap-4 max-w-5xl mx-auto w-full">
        
        <a href="/FL-Research-Lab/" class="font-extrabold text-xl tracking-tight text-text hover:text-rit-orange transition-colors">
          FL Research Lab
        </a>
        
        <nav class="flex items-center gap-6 text-sm font-semibold text-text-dim">
          <a href="/FL-Research-Lab/" class="hover:text-text transition-colors text-text font-bold">Home</a>
          <a href="/FL-Research-Lab/projects/" class="hover:text-rit-orange transition-colors">Projects</a>
          <a href="/FL-Research-Lab/publications/" class="hover:text-rit-orange transition-colors">Publications</a>
          <a href="/FL-Research-Lab/people/" class="hover:text-rit-orange transition-colors">People</a>
          <a href="/FL-Research-Lab/news/" class="hover:text-rit-orange transition-colors">News</a>
        </nav>

      </div>
    </header>

    <main class="w-full max-w-5xl mx-auto px-6 py-12 flex-1 relative z-10 prose max-w-none">
      <slot />
    </main>

    <footer class="w-full max-w-5xl mx-auto px-6 py-8 text-center text-xs text-text-faint border-t border-line relative z-10">
      &copy; {new Date().getFullYear()} FL Research Lab. Powered by Astro & Tailwind 4.
    </footer>

  </body>
</html>
